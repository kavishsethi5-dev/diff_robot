<?xml version="1.0"?>
<robot name="diff_robot">
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <material name="chassis">     <color rgba="0.25 0.28 0.32 1"/></material>
  <material name="teal">        <color rgba="0.11 0.72 0.55 1"/></material>
  <material name="orange_rim">  <color rgba="1.00 0.55 0.10 1"/></material>
  <material name="dark_rubber"> <color rgba="0.18 0.18 0.18 1"/></material>
  <material name="top_cap">     <color rgba="0.35 0.38 0.42 1"/></material>
  <material name="sensor_blue"> <color rgba="0.10 0.45 0.80 1"/></material>
  <material name="white">       <color rgba="1.00 1.00 1.00 1"/></material>

  <!-- Main chassis -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.36" length="0.06"/>
      </geometry>
      <material name="chassis"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.36" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.8"/>
      <inertia ixx="0.486" ixy="0" ixz="0" iyy="0.486" iyz="0" izz="0.729"/>
    </inertial>
  </link>

  <!-- Teal accent ring -->
  <link name="accent_ring">
    <visual>
      <geometry>
        <cylinder radius="0.37" length="0.018"/>
      </geometry>
      <material name="teal"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.001" length="0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00009"/>
    </inertial>
  </link>
  <joint name="accent_ring_joint" type="fixed">
    <parent link="base_link"/>
    <child link="accent_ring"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- Top plate cap -->
  <link name="top_plate">
    <visual>
      <geometry>
        <cylinder radius="0.34" length="0.012"/>
      </geometry>
      <material name="top_cap"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.001" length="0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0006"/>
    </inertial>
  </link>
  <joint name="top_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_plate"/>
    <origin xyz="0 0 0.036" rpy="0 0 0"/>
  </joint>

  <!-- Sensor dome -->
  <link name="sensor_dome">
    <visual>
      <geometry><cylinder radius="0.09" length="0.05"/></geometry>
      <material name="sensor_blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.09" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0010"/>
    </inertial>
  </link>
  <joint name="sensor_dome_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_dome"/>
    <origin xyz="0.08 0 0.055" rpy="0 0 0"/>
  </joint>

  <!-- Dome lens -->
  <link name="dome_lens">
    <visual>
      <geometry><cylinder radius="0.035" length="0.008"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.001" length="0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="dome_lens_joint" type="fixed">
    <parent link="sensor_dome"/>
    <child link="dome_lens"/>
    <origin xyz="0 0 0.029" rpy="0 0 0"/>
  </joint>

  <!-- Left wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.12" length="0.075"/></geometry>
      <material name="dark_rubber"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.12" length="0.075"/></geometry>
    </collision>
    <inertial>
      <mass value="0.72"/>
      <inertia ixx="0.0045" ixy="0" ixz="0" iyy="0.0045" iyz="0" izz="0.0045"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.39 -0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Left rim ring -->
  <link name="left_rim">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.085" length="0.080"/></geometry>
      <material name="orange_rim"/>
    </visual>
    <collision>
      <geometry><box size="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0003"/>
    </inertial>
  </link>
  <joint name="left_rim_joint" type="fixed">
    <parent link="left_wheel"/>
    <child link="left_rim"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Right wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.12" length="0.075"/></geometry>
      <material name="dark_rubber"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.12" length="0.075"/></geometry>
    </collision>
    <inertial>
      <mass value="0.72"/>
      <inertia ixx="0.0045" ixy="0" ixz="0" iyy="0.0045" iyz="0" izz="0.0045"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.39 -0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right rim ring -->
  <link name="right_rim">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.085" length="0.080"/></geometry>
      <material name="orange_rim"/>
    </visual>
    <collision>
      <geometry><box size="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0003"/>
    </inertial>
  </link>
  <joint name="right_rim_joint" type="fixed">
    <parent link="right_wheel"/>
    <child link="right_rim"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Skid plate rear -->
  <link name="skid_plate">
    <visual>
      <geometry><box size="0.15 0.18 0.015"/></geometry>
      <material name="top_cap"/>
    </visual>
    <collision>
      <geometry><box size="0.15 0.18 0.015"/></geometry>
    </collision>
    <inertial>
      <mass value="0.18"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00003"/>
    </inertial>
  </link>
  <joint name="skid_joint" type="fixed">
    <parent link="base_link"/>
    <child link="skid_plate"/>
    <origin xyz="-0.27 0 -0.1725" rpy="0 0 0"/>
  </joint>

  <!-- Skid plate front -->
  <link name="skid_plate_front">
    <visual>
      <geometry><box size="0.15 0.18 0.015"/></geometry>
      <material name="top_cap"/>
    </visual>
    <collision>
      <geometry><box size="0.15 0.18 0.015"/></geometry>
    </collision>
    <inertial>
      <mass value="0.18"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00003"/>
    </inertial>
  </link>
  <joint name="skid_joint_front" type="fixed">
    <parent link="base_link"/>
    <child link="skid_plate_front"/>
    <origin xyz="0.27 0 -0.1725" rpy="0 0 0"/>
  </joint>

  <gazebo reference="skid_plate">
    <mu1>0.1</mu1><mu2>0.1</mu2>
  </gazebo>
  <gazebo reference="skid_plate_front">
    <mu1>0.1</mu1><mu2>0.1</mu2>
  </gazebo>
  <gazebo reference="left_wheel">
    <mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel">
    <mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_model_pose>true</publish_model_pose>
      <publish_link_pose>false</publish_link_pose>
      <update_frequency>30</update_frequency>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.78</wheel_separation>
      <wheel_diameter>0.24</wheel_diameter>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <max_linear_velocity>1.0</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publisher_frequency>30</odom_publisher_frequency>
    </plugin>
  </gazebo>

</robot>